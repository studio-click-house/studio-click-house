{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "studio-click-house",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_als"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare"
  }
}
